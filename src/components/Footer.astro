</footer>

<style>
  .main-footer {
    background: #0a0a0a;
    border-top: 1px solid var(--border);
    padding: 6rem 0 3rem;
  }

  .footer-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    margin-bottom: 4rem;
  }

  .footer-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 2.2rem;
    letter-spacing: 5px;
    color: var(--gold);
    line-height: 1;
    margin-bottom: 0.4rem;
  }
  .footer-role {
    font-size: 0.62rem;
    letter-spacing: 2px;
    color: var(--muted);
    text-transform: uppercase;
    font-weight: 600;
    margin-bottom: 1.5rem;
  }
  .footer-skills {
    font-size: 0.6rem;
    letter-spacing: 1px;
    color: var(--muted-2);
    line-height: 2;
    text-transform: uppercase;
    font-weight: 600;
  }

  /* Connect */
  .connect-title {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.5rem;
    letter-spacing: 4px;
    color: var(--gold);
    margin-bottom: 0.4rem;
  }
  .connect-sub {
    font-size: 0.7rem;
    color: var(--muted);
    letter-spacing: 1px;
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    font-weight: 600;
  }
  .connect-icons {
    display: flex;
    gap: 1.2rem;
    margin-bottom: 2rem;
  }
  .connect-icons a {
    width: 44px;
    height: 44px;
    border: 1px solid var(--border);
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--muted-2);
    transition: border-color 0.2s, color 0.2s, background 0.2s;
  }
  .connect-icons a:hover {
    border-color: var(--gold);
    color: var(--gold);
    background: rgba(229, 169, 59, 0.08);
  }

  .cta-btn {
    display: inline-block;
    padding: 1rem 2.5rem;
    border: 2px solid var(--gold);
    color: var(--gold);
    font-size: 0.75rem;
    font-weight: 700;
    letter-spacing: 3px;
    text-transform: uppercase;
    border-radius: 2px;
    transition: background 0.3s, color 0.3s;
  }
  .cta-btn:hover {
    background: var(--gold);
    color: #000;
  }

  /* Bottom */
  .footer-bottom {
    border-top: 1px solid var(--border);
    padding-top: 2rem;
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.65rem;
    color: var(--muted-2);
    letter-spacing: 1.5px;
    text-transform: uppercase;
  }

  @media (max-width: 768px) {
    .footer-inner { grid-template-columns: 1fr; gap: 2.5rem; }
    .footer-bottom { flex-direction: column; gap: 0.5rem; text-align: center; }
  }
</style>
