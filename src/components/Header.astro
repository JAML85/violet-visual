---
const navItems = [
  { label: 'HOME', href: '#hero' },
  { label: 'SHOWS', href: '#shows' },
  { label: 'REEL', href: '#reel' },
  { label: 'STUDIOS', href: '#studios' },
  { label: 'portfolio', href: '#portfolio' },
  { label: 'ABOUT', href: '#about' },
];
---

<header class="main-header">
  <div class="container header-inner">
    <div class="brand">
      <div class="brand-name">JUAN MANCHADO</div>
      <div class="brand-role">SENIOR ENVIRONMENT &nbsp;·&nbsp; SETS &amp; PROPS MODELER</div>
    </div>

    <div class="header-right">
      <div class="social-icons">
        <a href="https://www.linkedin.com/in/juanmanchado3d" target="_blank" title="LinkedIn" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href="https://www.artstation.com" target="_blank" title="ArtStation" aria-label="ArtStation">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M0 17.723l2.027 3.505h.001a2.424 2.424 0 002.164 1.333h13.457l-2.792-4.838H0zm24 .025c0-.484-.143-.935-.388-1.314L15.728 2.728a2.424 2.424 0 00-2.164-1.333H9.419L21.598 22.54l1.92-3.325c.378-.656.482-.919.482-1.467zm-11.129-3.462L7.428 4.858l-5.444 9.428h10.887z"/></svg>
        </a>
        <a href="mailto:juan.manchado@gmail.com" title="Email" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="2" y="4" width="20" height="16" rx="2"/><path d="m2 7 10 7 10-7"/></svg>
        </a>
      </div>
      <nav class="main-nav">
        <ul class="nav-list">
          {navItems.map((item, i) => (
            <li>
              <a href={item.href} class={`nav-link ${i === 0 ? 'active' : ''}`}>{item.label}</a>
            </li>
          ))}
        </ul>
      </nav>
    </div>
  </div>
</header>

<style>
  .main-header {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    z-index: 1000;
    background: rgba(15, 15, 15, 0.96);
    border-bottom: 1px solid var(--border);
    transition: background 0.3s, box-shadow 0.3s;
    backdrop-filter: blur(8px);
  }
  .main-header.scrolled {
    box-shadow: 0 4px 30px rgba(0,0,0,0.6);
  }
  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 2rem;
    padding-top: 1rem;
    padding-bottom: 1rem;
  }
  .brand-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.9rem;
    letter-spacing: 4px;
    color: var(--gold);
    line-height: 1;
  }
  .brand-role {
    font-size: 0.62rem;
    letter-spacing: 2.5px;
    color: var(--muted);
    text-transform: uppercase;
    margin-top: 4px;
    font-weight: 600;
  }
  .header-right {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 0.6rem;
  }
  .social-icons {
    display: flex;
    gap: 1rem;
  }
  .social-icons a {
    color: var(--muted-2);
    transition: color 0.2s;
    display: flex;
    align-items: center;
  }
  .social-icons a:hover { color: var(--gold); }
  .nav-list {
    display: flex;
    gap: 1.6rem;
    align-items: center;
  }
  .nav-link {
    font-size: 0.68rem;
    font-weight: 700;
    letter-spacing: 2px;
    text-transform: uppercase;
    color: var(--muted);
    transition: color 0.2s;
    position: relative;
    padding-bottom: 2px;
  }
  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 1px;
    background: var(--gold);
    transition: width 0.3s;
  }
  .nav-link:hover,
  .nav-link.active {
    color: var(--gold);
  }
  .nav-link.active::after,
  .nav-link:hover::after {
    width: 100%;
  }

  @media (max-width: 768px) {
    .header-inner { flex-direction: column; align-items: flex-start; padding: 0.8rem 1.5rem; }
    .header-right { align-items: flex-start; }
    .nav-list { gap: 1rem; flex-wrap: wrap; }
    body { padding-top: 150px; }
  }
</style>
