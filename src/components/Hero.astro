---
---

<section class="hero" id="hero">
  <!-- Animated dot grid background -->
  <div class="hero-bg">
    <div class="dot-grid"></div>
    <div class="gradient-overlay"></div>
  </div>

  <div class="hero-content">
    <div class="eyebrow">Environment/ Sets and Props Modeler</div>
    <h1 class="hero-name">
      <span class="line">JUAN</span>
      <span class="line accent">MANCHADO</span>
    </h1>
    <div class="hero-role">Sets &amp; Props Modeler</div>
    <p class="hero-tagline">
      7+ years creating production-ready assets and environments<br>
      for international feature films and animated series.
    </p>
    <div class="platforms">
      <span>NETFLIX</span>
      <span class="dot-sep">·</span>
      <span>APPLE TV+</span>
      <span class="dot-sep">·</span>
      <span>PRIME VIDEO</span>
    </div>
    <div class="hero-cta">
      <a href="#shows" class="btn-outline">VIEW WORK</a>
      <a href="#about" class="btn-ghost">ABOUT ME</a>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span>SCROLL</span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    height: 100vh;
    min-height: 600px;
    display: flex;
    align-items: center;
    justify-content: center;
    text-align: center;
    overflow: hidden;
  }

  /* Background dot grid */
  .hero-bg {
    position: absolute;
    inset: 0;
  }
  .dot-grid {
    position: absolute;
    inset: 0;
    background-image: var(--dot-pattern);
    background-size: 24px 24px;
    opacity: 0.6;
    animation: drift 20s linear infinite;
  }
  @keyframes drift {
    0% { background-position: 0 0; }
    100% { background-position: 24px 24px; }
  }
  .gradient-overlay {
    position: absolute;
    inset: 0;
    background: radial-gradient(ellipse 80% 70% at 50% 50%, transparent 0%, var(--bg-0) 75%),
                linear-gradient(to bottom, var(--bg-0) 0%, transparent 20%, transparent 80%, var(--bg-0) 100%);
  }

  /* Content */
  .hero-content {
    position: relative;
    z-index: 2;
    max-width: 900px;
    padding: 2rem;
    animation: fadeUp 1s ease both;
  }
  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(30px); }
    to { opacity: 1; transform: translateY(0); }
  }

  .eyebrow {
    font-size: 0.7rem;
    letter-spacing: 5px;
    font-weight: 700;
    color: var(--gold);
    margin-bottom: 1.5rem;
    text-transform: uppercase;
    animation: fadeUp 1s 0.1s ease both;
  }

  .hero-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: clamp(4rem, 12vw, 9rem);
    line-height: 0.9;
    letter-spacing: 8px;
    display: flex;
    flex-direction: column;
    align-items: center;
    margin-bottom: 1.2rem;
  }
  .line { 
    display: block; 
    color: var(--text);
    animation: fadeUp 1s 0.2s ease both;
  }
  .line.accent { 
    color: var(--gold);
    animation-delay: 0.3s;
    /* Outlined style on second line for drama */
    -webkit-text-stroke: 1px var(--gold);
    color: transparent;
  }

  .hero-role {
    font-size: 1rem;
    letter-spacing: 4px;
    text-transform: uppercase;
    color: var(--muted);
    font-weight: 600;
    margin-bottom: 1.5rem;
    animation: fadeUp 1s 0.35s ease both;
  }

  .hero-tagline {
    font-size: 0.95rem;
    color: var(--muted);
    font-weight: 300;
    max-width: 580px;
    margin: 0 auto 2.5rem;
    line-height: 1.8;
    animation: fadeUp 1s 0.45s ease both;
  }

  .platforms {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.8rem;
    font-size: 0.65rem;
    letter-spacing: 3px;
    font-weight: 700;
    color: var(--muted-2);
    text-transform: uppercase;
    margin-bottom: 3rem;
    animation: fadeUp 1s 0.55s ease both;
  }
  .dot-sep { color: var(--gold); font-size: 0.5rem; }

  .hero-cta {
    display: flex;
    gap: 1.2rem;
    justify-content: center;
    animation: fadeUp 1s 0.65s ease both;
  }

  .btn-outline {
    padding: 0.9rem 2.8rem;
    border: 1.5px solid var(--gold);
    color: var(--gold);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    transition: background 0.3s, color 0.3s;
    border-radius: 2px;
  }
  .btn-outline:hover {
    background: var(--gold);
    color: #000;
  }
  .btn-ghost {
    padding: 0.9rem 2.8rem;
    border: 1.5px solid var(--border);
    color: var(--muted);
    font-size: 0.72rem;
    font-weight: 700;
    letter-spacing: 2.5px;
    text-transform: uppercase;
    transition: border-color 0.3s, color 0.3s;
    border-radius: 2px;
  }
  .btn-ghost:hover {
    border-color: var(--muted);
    color: var(--text);
  }

  /* Scroll hint */
  .scroll-hint {
    position: absolute;
    bottom: 2.5rem;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.5rem;
    z-index: 2;
    animation: fadeUp 1s 1s ease both;
  }
  .scroll-hint span {
    font-size: 0.55rem;
    letter-spacing: 3px;
    color: var(--muted-2);
    font-weight: 700;
  }
  .scroll-line {
    width: 1px;
    height: 50px;
    background: linear-gradient(to bottom, var(--gold), transparent);
    animation: scrollPulse 2s ease-in-out infinite;
  }
  @keyframes scrollPulse {
    0%, 100% { opacity: 0.3; transform: scaleY(0.8); }
    50% { opacity: 1; transform: scaleY(1); }
  }
</style>
