---
// Puedes añadir imports de Astro aquí si los necesitas en el futuro
---

<section class="studios-section" id="studios">
  <div class="container">
    <div class="section-label">
      <h2>STUDIOS & CLIENTS</h2>
      <p>COMPANIES I HAD THE PLEASURE TO WORK WITH</p>
    </div>

    <!-- MAPA CON TODOS LOS LOGOS CORREGIDOS (CON SKYDANCE VISIBLE) -->
    <div class="map-wrapper">
      <svg id="world-map" style="width:100%; display:block;"></svg>
      
      <div class="map-logos">
        <img src="/logos/prime.png" alt="Prime Video" class="map-logo logo-prime" />
        <img src="/logos/netflix.png" alt="Netflix" class="map-logo logo-netflix" />
        <img src="/logos/skydance.png" alt="Skydance Animation" class="map-logo logo-skydance" />
        
        <!-- Logos con cajas de fondo claro que necesitan integración -->
        <img src="/logos/anima.jpg" alt="Anima Kitchent" class="map-logo logo-blended logo-anima" />
        <img src="/logos/do.png" alt="DØ Postproduction" class="map-logo logo-blended logo-dopost" />
        <img src="/logos/frank.jpg" alt="The Frank Barton Company" class="map-logo logo-blended logo-frank" />
        <img src="/logos/motion.jpg" alt="The Motion Logic Studios" class="map-logo logo-blended logo-motion" />
        <img src="/logos/hampa.jpg" alt="Hampa Studio" class="map-logo logo-blended logo-hampa" />
        <img src="/logos/toneplus.jpg" alt="Toneplus Animation" class="map-logo logo-blended logo-toneplus" />
      </div>
    </div>

    <!-- GRID INFERIOR DE CIUDADES -->
    <div class="cities-grid">
      <div class="city-block">
        <div class="city-name">MADRID</div>
        <div class="city-divider"></div>
        <div class="city-studio">Tandem Films</div>
        <div class="city-studio">DØ Postproduction</div>
        <div class="city-studio">Able&Baker</div>
        <div class="city-studio">The Frank Barton Company</div>
        <div class="city-studio">Skydance Animation</div>
      </div>
      <div class="city-block">
        <div class="city-name">VALENCIA</div>
        <div class="city-divider"></div>
        <div class="city-studio">Hampa Studio</div>
        <div class="city-studio">La Cancan</div>
      </div>
      <div class="city-block">
        <div class="city-name">USA</div>
        <div class="city-divider"></div>
        <div class="city-studio">Thelma & Boom, Inc.</div>
        <div class="city-studio">The Motion Logic Studios</div>
      </div>
      <div class="city-block">
        <div class="city-name">Canarias</div>
        <div class="city-divider"></div>
        <div class="city-studio">Anima Kitchent</div>
        <div class="city-studio">B-Water</div>
        <div class="city-studio">Atlantis</div>
      </div>
      <div class="city-block">
        <div class="city-name">INTL.</div>
        <div class="city-divider"></div>
        <div class="city-studio">Blit Studio</div>
        <div class="city-studio">Non-Fungible Labs</div>
        <div class="city-studio">Hololux VR</div>
        <div class="city-studio">Toneplus Animation</div>
      </div>
    </div>
  </div>
</section>

<style>
  .studios-section {
    padding: 7rem 0;
    background: #0b0b0b;
    border-top: 1px solid #1a1a1a;
  }
  
  .map-wrapper {
    position: relative;
    width: 100%;
    border-radius: 4px;
    overflow: hidden;
    margin-bottom: 3rem;
    background: #0f0f0f;
    border: 1px solid #1a1a1a;
  }

  .map-logos {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
  }

  /* ESTILO BASE PARA TODOS LOS LOGOS */
  .map-logo {
    position: absolute;
    z-index: 10;
    width: auto;
    max-width: 115px;
    height: auto;
    opacity: 0.85;
    transition: all 0.3s ease;
    pointer-events: auto;
    object-fit: contain;
  }

  /* CLASE ESPECÍFICA PARA LOS LOGOS CON FONDO CLARO (Elimina el parche cuadrado de fondo) */
  .logo-blended {
    mix-blend-mode: multiply;
    filter: brightness(1.2); /* Les da un extra de luz para que resalten sobre el fondo oscuro */
  }

  /* Efecto Hover limpio */
  .map-logo:hover {
    opacity: 1;
    transform: scale(1.05);
  }

  /* DISTRIBUCIÓN UNIFORME POR EL MAPA */
  .logo-prime      { top: 22%; left: 12%; max-height: 100px; } 
  .logo-skydance   { top: 40%; left: 24%; max-height: 100px; } /* Ajustado posición y tamaño para que no se pise */
  .logo-anima      { top: 68%; left: 16%; max-height: 100px; } 
  
  .logo-netflix    { top: 18%; left: 46%; max-height: 100px; } 
  .logo-frank      { top: 46%; left: 45%; max-height: 100px; } 
  
  .logo-dopost     { top: 28%; left: 74%; max-height: 100px; } 
  .logo-hampa      { top: 52%; left: 64%; max-height: 100px; } 
  .logo-motion     { top: 64%; left: 84%; max-height: 100px; } 
  .logo-toneplus   { top: 82%; left: 70%; max-height: 100px; }

  /* Grid inferior de ciudades */
  .cities-grid {
    display: grid;
    grid-template-columns: repeat(5, 1fr);
    gap: 2rem;
    border-top: 1px solid #1a1a1a;
    padding-top: 3rem;
  }
  .city-block { text-align: center; }
  .city-name {
    font-family: 'Bebas Neue', sans-serif;
    font-size: 1.2rem;
    letter-spacing: 4px;
    color: #e5a93b;
    margin-bottom: 0.5rem;
  }
  .city-divider {
    width: 24px; height: 2px;
    background: #e5a93b;
    margin: 0 auto 1rem;
  }
  .city-studio {
    font-size: 0.65rem;
    color: #888;
    font-weight: 600;
    letter-spacing: 0.5px;
    line-height: 2.2;
    text-transform: uppercase;
  }
  
  @media (max-width: 900px) { 
    .cities-grid { grid-template-columns: repeat(3,1fr); } 
  }
  @media (max-width: 600px) { 
    .cities-grid { grid-template-columns: repeat(2,1fr); }
    .map-logo { max-height: 20px !important; max-width: 55px; }
  }
</style>

<script>
  async function drawMap() {
    const [d3mod, topo] = await Promise.all([
      import('https://cdn.jsdelivr.net/npm/d3@7/+esm'),
      import('https://cdn.jsdelivr.net/npm/topojson-client@3/+esm'),
    ]);

    const svg = d3mod.select("#world-map");
    const rect = (svg.node() as SVGElement).parentElement!.getBoundingClientRect();
    const W = rect.width;
    const H = Math.round(W * 0.52);
    svg.attr("viewBox", `0 0 ${W} ${H}`).attr("height", H);

    const proj = d3mod.geoNaturalEarth1()
      .scale(W / 6.1)
      .translate([W / 2, H / 2]);
    const path = d3mod.geoPath().projection(proj);

    const worldUrl = "https://cdn.jsdelivr.net/npm/world-atlas@2/countries-110m.json";
    const world: any = await d3mod.json(worldUrl);
    const countries = topo.feature(world, world.objects.countries) as any;

    svg.append("rect").attr("width", W).attr("height", H).attr("fill", "#0f0f0f");
    
    svg.append("g")
      .selectAll("path")
      .data(countries.features)
      .join("path")
      .attr("d", path)
      .attr("fill", "#1e1e1e")
      .attr("stroke", "#121212")
      .attr("stroke-width", 0.6);
  }

  drawMap();
</script>