---
// src/pages/projects/superthings.astro
// Juan Manchado — Superthings Portfolio Page
---

<html lang="es">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Super Things — Juan Manchado</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=DM+Mono:wght@300;400&family=Syne:wght@700;800&family=DM+Sans:wght@400;500&display=swap" rel="stylesheet" />

  <style>
    :root {
      --bg: #050505;
      --surface: #0d0d0d;
      --border: rgba(255,255,255,0.07);
      --text: #e8e8e6;
      --text-muted: #6b6b68;
      --accent: #c8ff00;
      --font-display: 'Syne', sans-serif;
      --font-body: 'DM Sans', sans-serif;
      --font-mono: 'DM Mono', monospace;
    }

    * { margin: 0; padding: 0; box-sizing: border-box; }
    body { background: var(--bg); color: var(--text); font-family: var(--font-body); padding: 4rem 2rem; -webkit-font-smoothing: antialiased; }
    .container { max-width: 1100px; margin: 0 auto; }
    
    /* Botón Volver */
    .back-link { font-family: var(--font-mono); font-size: 0.75rem; color: var(--text-muted); text-decoration: none; text-transform: uppercase; letter-spacing: 0.1em; display: inline-flex; align-items: center; gap: 0.5rem; margin-bottom: 3rem; transition: color 0.2s; }
    .back-link:hover { color: var(--accent); }

    /* Cabecera de Proyecto */
    header { margin-bottom: 4rem; }
    .project-title { font-family: var(--font-display); font-size: clamp(2.5rem, 5vw, 4.5rem); font-weight: 800; line-height: 1; letter-spacing: -0.04em; margin-bottom: 0.5rem; }
    .project-meta { font-family: var(--font-mono); font-size: 0.72rem; color: var(--accent); text-transform: uppercase; letter-spacing: 0.15em; }
    .project-desc { font-size: 1.05rem; color: #9a9a97; max-width: 60ch; margin-top: 1.5rem; line-height: 1.7; }

    /* Contenedor de Vídeo Responsivo (16:9) */
    .video-wrapper { position: relative; padding-bottom: 56.25%; height: 0; overflow: hidden; background: var(--surface); border: 1px solid var(--border); border-radius: 2px; margin-bottom: 3rem; box-shadow: 0 20px 40px rgba(0,0,0,0.5); }
    .video-wrapper iframe { position: absolute; top: 0; left: 0; width: 100%; height: 100%; border: 0; }

    /* Grid de Renders e Imágenes */
    .renders-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: 1.5rem; margin-top: 3rem; }
    .render-item { background: var(--surface); border: 1px solid var(--border); border-radius: 2px; overflow: hidden; }
    .render-item img { width: 100%; height: auto; display: block; filter: brightness(0.9); transition: filter 0.3s; }
    .render-item img:hover { filter: brightness(1); }

    @media (max-width: 768px) {
      .renders-grid { grid-template-columns: 1fr; }
      body { padding: 2rem 1rem; }
    }
  </style>
</head>
<body>

  <div class="container">
    <a href="/" class="back-link">← Volver al inicio</a>

    <header>
      <p class="project-meta">Largometraje · Animación</p>
      <h1 class="project-title">Super Things: Rivals of Kaboom</h1>
      <p class="project-meta" style="color: var(--text-muted)">Tandem Films · Hero Props Modeler</p>
      <p class="project-desc">
        Modelado de sets de ambientación y hero props de alta densidad para el largometraje. 
        Flujo de trabajo optimizado para pipeline de animación internacional con topología limpia y bakes limpios.
      </p>
    </header>

    <div class="video-wrapper">
      <iframe 
        src="https://www.youtube.com/embed/zavCzfxAEbg?start=4701&rel=0&modestbranding=1" 
        title="Superthings Breakdown"
        allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture" 
        allowfullscreen>
      </iframe>
    </div>

    <div class="renders-grid">
      <div class="render-item">
      </div>
      <div class="render-item">
      </div>
    </div>

  </div>

</body>
</html>